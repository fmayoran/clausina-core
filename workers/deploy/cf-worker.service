[Unit]
Description=cf worker (cola Redis -> handlers; ejecuta claude -p headless)
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/claudefolder/plataforma/workers
Environment=HOME=/root
Environment=REDIS_URL=redis://localhost:6380/0
Environment=AGENT_BACKEND=headless
ExecStart=/usr/bin/python3 /root/claudefolder/plataforma/workers/worker.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
